# ==========================================
# Application
# ==========================================
NODE_ENV=development
PORT=3000

# ==========================================
# Database
# ==========================================
DATABASE_URL="postgresql://user:password@localhost:5432/anime_tracker"
DATABASE_URL_TEST="postgresql://user:password@localhost:5432/anime_tracker_test"

# ==========================================
# Authentication
# ==========================================
JWT_SECRET="your-jwt-secret"
JWT_EXPIRES_IN="1d"

# ==========================================
# CORS
# ==========================================
CORS_ORIGIN="http://localhost:5173"

# ==========================================
# Anime Provider
# ==========================================
ANIME_PROVIDER="kitsu"
KITSU_BASE_URL="https://kitsu.io/api/edge"

# ==========================================
# Cloudinary
# ==========================================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"